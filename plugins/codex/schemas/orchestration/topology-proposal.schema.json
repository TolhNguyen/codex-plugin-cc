{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TopologyProposal",
  "description": "Manager-proposed agent topology and skill drafts for a repository, pending approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topologyType",
    "rationale",
    "agents",
    "skillDrafts",
    "overlaps",
    "risks"
  ],
  "properties": {
    "topologyType": {
      "type": "string",
      "enum": [
        "domain-oriented",
        "layer-oriented",
        "workflow-oriented",
        "hybrid"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "type",
          "responsibilities",
          "ownership",
          "permissions",
          "skills",
          "rationale"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "persistent",
              "temporary-template"
            ]
          },
          "responsibilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "ownership": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "primary",
              "secondary",
              "excluded"
            ],
            "properties": {
              "primary": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "secondary": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "excluded": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "permissions": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "read",
              "write"
            ],
            "properties": {
              "read": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "write": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "skillDrafts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "purpose",
          "sources"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(core|technical|project|domain)/[a-z0-9-]+$"
          },
          "purpose": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "useWhen": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "procedure": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verificationSteps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "overlaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
