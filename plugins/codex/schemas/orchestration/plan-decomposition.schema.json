{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanDecomposition",
  "description": "Manager output contract decomposing a written plan into tier-classified task drafts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tasks"
  ],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "goal",
          "affectedPaths",
          "contextFiles",
          "verificationCommands",
          "acceptanceCriteria",
          "requiredSkills",
          "tier",
          "tierRationale"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "affectedPaths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "contextFiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verificationCommands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "requiredSkills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tier": {
            "type": "string",
            "enum": [
              "worker",
              "manager",
              "executive"
            ]
          },
          "tierRationale": {
            "type": "string"
          }
        }
      }
    }
  }
}
